{
	"server": {
		"port": 3000,
		"env": "development",
		"cors": {
			"origin": ["http://localhost:8080", "http://localhost:3001"],
			"credentials": true
		}
	},
	"database": {
		"path": "./db",
		"users_file": "./db/users.csv",
		"blacklist_file": "./db/token-blacklist.csv",
		"sessions_file": "./db/sessions.csv",
		"shopping_lists_dir": "./db/shopping-lists"
	},
	"auth": {
		"bcrypt_rounds": 10,
		"password_min_length": 8,
		"session_expiry_days": 30,
		"session_rotation_days": 7,
		"jwt_secret": "your-secret-key-change-in-production"
	},
	"limits": {
		"max_items_per_list": 1000,
		"max_sections_per_list": 50,
		"max_lists_per_user": 100,
		"max_username_length": 32,
		"max_list_name_length": 100,
		"max_item_name_length": 200,
		"max_section_name_length": 50
	},
	"rateLimit": {
		"enabled": true,
		"windowMs": 60000,
		"max": 100,
		"skipSuccessfulRequests": false
	},
	"logging": {
		"level": "info",
		"format": "json"
	},
	"server.port": 3000,
	"server.env": "development",
	"auth.bcrypt_rounds": 10,
	"auth.password_min_length": 8,
	"auth.session_expiry_days": 30,
	"auth.session_rotation_days": 7,
	"limits.max_items_per_list": 1000,
	"limits.max_sections_per_list": 50,
	"limits.max_lists_per_user": 100,
	"limits.max_username_length": 32,
	"limits.max_list_name_length": 100,
	"limits.max_item_name_length": 200,
	"limits.max_section_name_length": 50,
	"rateLimit.enabled": true,
	"rateLimit.windowMs": 60000,
	"rateLimit.max": 100,
	"logging.level": "warn"
}
