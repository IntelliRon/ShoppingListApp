	"version": "1.0.0",
	"description": "Shopping List App - Backend API Server",
	"main": "src/index.js",
	"scripts": {
		"start": "node src/index.js",
		"dev": "NODE_ENV=development node src/index.js",
		"test": "jest --passWithNoTests",
