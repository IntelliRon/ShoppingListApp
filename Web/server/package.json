		"csv-writer": "^1.6.0",
		"dotenv": "^16.0.3",
		"express": "^4.18.2",
		"express-rate-limit": "^6.7.0",
		"jsonwebtoken": "^9.0.0",
		"uuid": "^14.0.1"
	},
	"devDependencies": {
		"eslint": "^8.40.0",
		"jest": "^29.5.0",
		"nodemon": "^3.1.14",
		"supertest": "^6.3.3"
	},
	"engines": {
		"node": ">=16.0.0",
		"npm": ">=8.0.0"
