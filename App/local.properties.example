# Local Android SDK Configuration Template
# This file is a TEMPLATE for local development. Copy it to local.properties and customize:
#
#   cp local.properties.example local.properties
#
# The local.properties file (not this template) must NOT be checked into VCS,
# as it contains information specific to your machine's local configuration.

# Location of the SDK. This is only used by Gradle.
# For customization when using a locally built SDK (instead of downloading it),
# comment out the following line and uncomment the next lines:
sdk.dir=/path/to/Android/sdk

# ndk.dir=/path/to/ndk
